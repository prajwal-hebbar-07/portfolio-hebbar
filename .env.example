# ── Portfolio Assistant (/assistant) ─────────────────────────────────────────
# Base URL of the Go portfolio API. The /assistant page posts prompts to the
# same-origin proxy /api/portfolio/ask, which forwards them to
# ${PORTFOLIO_API_URL}/api/v1/portfolio/ask. If the backend is unreachable, the
# proxy serves a grounded, on-topic offline answer so the assistant still works.
# (127.0.0.1 rather than localhost avoids Node trying IPv6 ::1 first.)
PORTFOLIO_API_URL=http://127.0.0.1:8000

# ── Floating site assistant (/api/chat, optional) ────────────────────────────
# Anthropic API key for the Claude-backed chat endpoint (server-side only —
# never exposed to the browser). Without it, /api/chat falls back to a
# deterministic, still-grounded canned answer.
ANTHROPIC_API_KEY=

# Optional: override the Claude model that endpoint uses. Defaults to
# claude-opus-4-8. For a faster / cheaper assistant set this to claude-haiku-4-5.
CLAUDE_MODEL=claude-opus-4-8
