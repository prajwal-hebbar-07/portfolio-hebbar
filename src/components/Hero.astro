---
import { profile } from '../data/portfolio';
---

<section class="hero" id="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="mesh m1"></div>
    <div class="mesh m2"></div>
    <div class="mesh m3"></div>
    <div class="grid"></div>
    <div class="vignette"></div>
  </div>

  <div class="wrap hero-inner">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="badge reveal in">
          <span class="pulse"></span> Available for opportunities
        </span>

        <h1 class="reveal in" data-delay="1">{profile.name}</h1>

        <p class="role-statement reveal in" data-delay="2">
          <span class="rs-role">Senior Engineer</span> building configurable, enterprise-grade
          web platforms with <b>React</b>, <b>TypeScript</b> &amp;
          <b class="accent">thoughtful design systems</b>.
        </p>

        <div class="hero-cta reveal in" data-delay="3">
          <a class="btn btn-primary" href="#contact">
            <svg class="ic" data-lucide="send"></svg> Get in touch
          </a>
          <button class="btn btn-ghost" type="button" data-open-chat>
            <svg class="ic" data-lucide="sparkles"></svg> Ask the AI about me
          </button>
        </div>
      </div>

      <!-- Quick-scan profile card -->
      <aside class="spec-card reveal in" data-delay="3" aria-label="Profile at a glance">
        <div class="sc-top">
          <span>At a glance</span>
          <span class="dots"><i></i><i></i><i></i></span>
        </div>
        <div class="spec-row wide"><span class="k">Focus</span><span class="v">React · TypeScript · <span class="hl">Design Systems</span></span></div>
        <div class="spec-row"><span class="k">Current</span><span class="v"><span class="hl">Senior Engineer</span> @ LYIK</span></div>
        <div class="spec-row"><span class="k">Experience</span><span class="v">~5 years</span></div>
        <div class="spec-row"><span class="k">Impact</span><span class="v"><span class="hl">30%+</span> efficiency gains</span></div>
        <div class="spec-row"><span class="k">Location</span><span class="v">{profile.location}</span></div>
        <div class="spec-row"><span class="k">Status</span><span class="v"><span class="hl">Open to work</span></span></div>
        <div class="sc-foot">
          <span class="chip">TypeScript</span>
          <span class="chip">Redux</span>
          <span class="chip">Node.js</span>
          <span class="chip">Docker</span>
        </div>
      </aside>
    </div>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <span class="mouse"></span>
    Scroll
  </div>
</section>
