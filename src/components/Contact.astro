---
import { profile } from '../data/portfolio';
const linkedinSvg =
  '<svg class="ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33 0-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .77 0 1.73v20.54C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/></svg>';
const githubSvg =
  '<svg class="ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.7 18 5 18 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>';
---

<section class="section" id="contact">
  <div class="wrap">
    <div class="contact-wrap">
      <div class="contact-lead reveal">
        <span class="eyebrow">Contact</span>
        <h2>Let's build something <span class="accent">effortless</span>.</h2>
        <p>Open to full-time roles and freelance work in React, Next.js, and Web3/AI. I usually reply within a day.</p>
        <a class="btn btn-primary" href={`mailto:${profile.email}`}>
          <svg class="ic" data-lucide="send"></svg> Start a conversation
        </a>
      </div>

      <div class="contact-list reveal" data-delay="2">
        <a class="card contact-row" href={`mailto:${profile.email}`}>
          <span class="cr-ic"><svg class="ic" data-lucide="mail"></svg></span>
          <span class="cr-body">
            <span class="cr-label">Email</span>
            <span class="cr-value">{profile.email}</span>
          </span>
          <span class="cr-arrow"><svg class="ic" data-lucide="arrow-up-right"></svg></span>
        </a>
        <a class="card contact-row" href={`tel:${profile.phoneHref}`}>
          <span class="cr-ic"><svg class="ic" data-lucide="phone"></svg></span>
          <span class="cr-body">
            <span class="cr-label">Phone</span>
            <span class="cr-value">{profile.phone}</span>
          </span>
          <span class="cr-arrow"><svg class="ic" data-lucide="arrow-up-right"></svg></span>
        </a>
        <a class="card contact-row" href={profile.linkedin} target="_blank" rel="noopener">
          <span class="cr-ic" set:html={linkedinSvg}></span>
          <span class="cr-body">
            <span class="cr-label">LinkedIn</span>
            <span class="cr-value">{profile.linkedinLabel}</span>
          </span>
          <span class="cr-arrow"><svg class="ic" data-lucide="arrow-up-right"></svg></span>
        </a>
        <a class="card contact-row" href={profile.github} target="_blank" rel="noopener">
          <span class="cr-ic" set:html={githubSvg}></span>
          <span class="cr-body">
            <span class="cr-label">GitHub</span>
            <span class="cr-value">{profile.githubLabel}</span>
          </span>
          <span class="cr-arrow"><svg class="ic" data-lucide="arrow-up-right"></svg></span>
        </a>
      </div>
    </div>
  </div>
</section>
